{
  "CephOptions": {
    "BaseUri": "https://s3.yandexcloud.net",
    "BucketName": "peerly-storage-bucket-1",
    "ForcePathStyle": true,
    "ExpirationTime": "00:30:00",
    "LongLifeExpirationTime": "01:00:00"
  },
  "HomeworkDistributionJob": {
    "MaxFailCount": 3,
    "ProcessTimeoutSeconds": 300,
    "MaxDegreeOfParallelism": 3,
    "BatchSize": 50
  },
  "ReviewCompletionJob": {
    "MaxFailCount": 3,
    "ProcessTimeoutSeconds": 300,
    "MaxDegreeOfParallelism": 3,
    "BatchSize": 50
  },
  "KafkaConsumer": {
    "BootstrapServers": "localhost:9092",
    "GroupId": "peerly-core-consumer",
    "Topic": "user_registration_events",
    "EnableAutoCommit": false,
    "AutoOffsetReset": "earliest"
  }
}
